# ============================================
# Aura-Pet 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填入你的真实值
# 
# ⚠️ 重要安全须知：
# 1. .env 文件绝对不要提交到 Git！
# 2. 已添加到 .gitignore
# 3. 生产环境使用 GitHub Secrets
# ============================================

# ========== 数据库 ==========
DATABASE_URL=postgresql://aura_pet:aura_pet@localhost:5432/aura_pet
REDIS_URL=redis://localhost:6379

# ========== 安全密钥 ==========
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-with-secure-random-key

# ========== AI 服务密钥 (关键！) ==========

# Google Gemini API Key
# 获取地址: https://makersuite.google.com/app/apikey
# ⚠️ 绝对不要提交到 GitHub！
GEMINI_API_KEY=

# OpenAI API Key (可选)
OPENAI_API_KEY=

# ========== 支付 (可选) ==========
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== 环境配置 ==========
ENVIRONMENT=development
DEBUG=true
